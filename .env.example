# 환경변수 예시 (형식·키만 — 실제 값은 .env에 채우고 커밋하지 않는다)
#
# 사용법: `cp .env.example .env` 후 값 채우기.
# 전파 체인: .env.example → .env → compose.yml(${KEY}) → dg.EnvVar/os.environ
# 상세: docs/operations.md

# --- Postgres (Dagster 메타데이터 + Iceberg JDBC 카탈로그) ---
POSTGRES_USER=dagster
POSTGRES_PASSWORD=            # 비밀 — 임의의 강한 값으로 채운다
POSTGRES_DB=dagster
POSTGRES_PORT=5432

# --- Dagster ---
DAGSTER_PORT=3000            # webserver UI 포트

# --- AWS / S3 (SeaweedFS S3 호환) ---
AWS_ACCESS_KEY_ID=           # 비밀 — SeaweedFS S3 액세스 키
AWS_SECRET_ACCESS_KEY=       # 비밀 — SeaweedFS S3 시크릿 키
AWS_DEFAULT_REGION=us-east-1
ENDPOINT_URL=http://seaweedfs:8333   # 컨테이너 네트워크 내부 S3 엔드포인트

# --- Discord 봇 / Ollama Cloud ---
DISCORD_BOT_TOKEN=           # 비밀 — Discord 봇 토큰
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=              # 비밀 — Ollama Cloud API 키
OLLAMA_MODEL=gpt-oss:20b     # 예시 모델명
